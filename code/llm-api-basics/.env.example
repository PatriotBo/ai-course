# 默认 mock：不调用外部 API，适合本地学习和测试
LLM_PROVIDER=mock

# 统一配置：切换模型时优先改这四项
# 支持的 LLM_PROVIDER：mock / openai / openai_compatible / glm / hunyuan
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# 生成参数
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=512
LLM_TIMEOUT_SECONDS=30

# 示例 1：智谱 GLM（OpenAI-compatible）
# LLM_PROVIDER=glm
# LLM_API_KEY=你的智谱 API Key，或使用环境变量 ZAI_API_KEY
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
# LLM_MODEL=glm-5.2

# 示例 2：腾讯混元 Hunyuan（OpenAI-compatible）
# LLM_PROVIDER=hunyuan
# LLM_API_KEY=你的混元 API Key，或使用环境变量 HUNYUAN_API_KEY
# LLM_BASE_URL=https://api.hunyuan.cloud.tencent.com/v1
# LLM_MODEL=hunyuan-turbos-latest

# 兼容旧变量名：代码仍会读取 OPENAI_API_KEY / OPENAI_BASE_URL / OPENAI_MODEL
# 但课程示例后续统一推荐 LLM_API_KEY / LLM_BASE_URL / LLM_MODEL。
