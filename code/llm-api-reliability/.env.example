# 真实 provider 配置。后续课程默认使用真实 OpenAI-compatible provider，不默认生成 mock。

# GLM / 智谱
LLM_PROVIDER=glm
LLM_API_KEY=你的智谱_API_Key
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
LLM_MODEL=glm-5.2

# 腾讯混元示例：需要时把上面的 GLM 配置替换为下面这组
# LLM_PROVIDER=hunyuan
# LLM_API_KEY=你的混元_API_Key
# LLM_BASE_URL=https://api.hunyuan.cloud.tencent.com/v1
# LLM_MODEL=hunyuan-turbos-latest

# 通用 OpenAI-compatible 示例
# LLM_PROVIDER=openai_compatible
# LLM_API_KEY=你的_API_Key
# LLM_BASE_URL=https://your-provider.example.com/v1
# LLM_MODEL=your-model-name

# 可靠性参数
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=3
LLM_BASE_DELAY_SECONDS=1
LLM_MAX_DELAY_SECONDS=20
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=512
LLM_LOG_PATH=logs/llm_reliability.jsonl

# 成本估算，单位：元 / 1M tokens。按你当前 provider 价格手动配置。
LLM_INPUT_PRICE_PER_1M=0
LLM_OUTPUT_PRICE_PER_1M=0
