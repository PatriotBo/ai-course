# 默认使用 mock provider，不产生模型费用
LLM_PROVIDER=mock
LLM_MODEL=mock-stream-model
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=512
LLM_TIMEOUT_SECONDS=60
LLM_STREAM_LOG_PATH=logs/llm_streams.jsonl

# GLM / 智谱 OpenAI-compatible 示例
# LLM_PROVIDER=glm
# LLM_API_KEY=你的智谱_API_Key
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
# LLM_MODEL=glm-5.2

# 腾讯混元 OpenAI-compatible 示例
# LLM_PROVIDER=hunyuan
# LLM_API_KEY=你的混元_API_Key
# LLM_BASE_URL=https://api.hunyuan.cloud.tencent.com/v1
# LLM_MODEL=hunyuan-turbos-latest

# 通用 OpenAI-compatible 服务
# LLM_PROVIDER=openai_compatible
# LLM_API_KEY=你的_API_Key
# LLM_BASE_URL=https://your-provider.example.com/v1
# LLM_MODEL=your-model-name
